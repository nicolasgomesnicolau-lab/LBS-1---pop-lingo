# LBS #1 — Environment Variables (example)
# Copy this file to .env and fill in the values

# YouTube Data API v3 (used server-side for search)
YT_API_KEY=your_youtube_api_key_here

# Jarvis Karaoke API (default: https://lbs-1-api-jarvis-for-pop-lingo.onrender.com)
KARAOKE_NGROK=https://your-render-url.onrender.com
KARAOKE_API_KEY=your_jarvis_api_key_here

# OpenRouter (AI chat + translate)
OPENROUTER_KEY=sk-or-v1-your_openrouter_key_here

# Admin password for Movies tab admin panel
ADMIN_PASSWORD=your_admin_password_here

# GitHub token for auto-committing movies.json (optional)
GITHUB_TOKEN=your_github_token_here

# Supabase (database for shared storage)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
